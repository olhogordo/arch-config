# Dunst - Gruvbox Theme
[global]
font = JetBrainsMono Nerd Font 10
notify_timeout = 5
show_age_threshold = 60
sticky_history = yes
history_length = 20
corner_radius = 8

[urgency_low]
background = "#282828"
foreground = "#ebdbb2"
frame_color = "#928374"

[urgency_normal]
background = "#282828"
foreground = "#ebdbb2"
frame_color = "#fe8019"

[urgency_critical]
background = "#fb4934"
foreground = "#1d2021"
frame_color = "#fb4934"
