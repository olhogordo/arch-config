# ==========================================================
# I3WM — GRUVBOX DARK HARD
# Setup pessoal, operacional, sem lixo
# ==========================================================

# ---------- VARIAVEIS ----------
set $mod Mod4
set $terminal alacritty
set $browser firefox
set $file_manager thunar
set $editor obsidian
set $launcher rofi -show drun -theme ~/.config/rofi/config.rasi
set $window_switcher rofi -show window -theme ~/.config/rofi/config.rasi

# ---------- FONTE ----------
font pango:JetBrainsMono Nerd Font 10

# ---------- GAPS ----------
gaps inner 8
gaps outer 0
smart_gaps on
smart_borders on

# ---------- BORDAS ----------
default_border pixel 2
default_floating_border pixel 2
hide_edge_borders smart

# ---------- CORES GRUVBOX ----------
# Formato: border background text indicator child_border
client.focused          #fe8019 #1d2021 #ebdbb2 #fe8019 #fe8019
client.focused_inactive #3c3836 #1d2021 #928374 #3c3836 #3c3836
client.unfocused        #3c3836 #1d2021 #928374 #3c3836 #3c3836
client.urgent           #fb4934 #1d2021 #1d2021 #fb4934 #fb4934
client.placeholder      #1d2021 #1d2021 #928374 #1d2021 #1d2021
client.background       #1d2021

# ---------- FOCO ----------
focus_wrapping no
focus_follows_mouse no
mouse_warping output
workspace_auto_back_and_forth yes

# ---------- AUTOSTART ----------
exec --no-startup-id dex --autostart --environment i3
exec --no-startup-id feh --no-fehbg --bg-fill ~/mid/wallpapers/wallhaven-qzqqp7.png
exec --no-startup-id setxkbmap -layout us -variant intl
exec --no-startup-id xss-lock --transfer-sleep-lock -- i3lock --nofork
exec --no-startup-id nm-applet

# ---------- LANÇADORES ----------
bindsym $mod+Return exec $terminal
bindsym $mod+b exec $browser
bindsym $mod+o exec $editor
bindsym $mod+t exec $file_manager
bindsym $mod+d exec $launcher
bindsym $mod+Tab exec $window_switcher
bindsym $mod+Shift+Return exec $terminal --class floating

# ---------- CONTROLE DE JANELAS ----------
bindsym $mod+Shift+q kill
bindsym $mod+f fullscreen toggle
bindsym $mod+Shift+space floating toggle
bindsym $mod+space focus mode_toggle
bindsym $mod+a focus parent
bindsym $mod+Shift+a focus child

# ---------- NAVEGAÇÃO ----------
bindsym $mod+h focus left
bindsym $mod+j focus down
bindsym $mod+k focus up
bindsym $mod+l focus right
bindsym $mod+Left focus left
bindsym $mod+Down focus down
bindsym $mod+Up focus up
bindsym $mod+Right focus right

# ---------- MOVER JANELAS ----------
bindsym $mod+Shift+h move left
bindsym $mod+Shift+j move down
bindsym $mod+Shift+k move up
bindsym $mod+Shift+l move right
bindsym $mod+Shift+Left move left
bindsym $mod+Shift+Down move down
bindsym $mod+Shift+Up move up
bindsym $mod+Shift+Right move right

# ---------- SPLITS E LAYOUT ----------
bindsym $mod+semicolon split h
bindsym $mod+v split v
bindsym $mod+s layout stacking
bindsym $mod+w layout tabbed
bindsym $mod+e layout toggle split

# ---------- WORKSPACES ----------
set $ws1 "1"
set $ws2 "2"
set $ws3 "3"
set $ws4 "4"
set $ws5 "5"
set $ws6 "6"
set $ws7 "7"
set $ws8 "8"
set $ws9 "9"
set $ws10 "10"

bindsym $mod+1 workspace number $ws1
bindsym $mod+2 workspace number $ws2
bindsym $mod+3 workspace number $ws3
bindsym $mod+4 workspace number $ws4
bindsym $mod+5 workspace number $ws5
bindsym $mod+6 workspace number $ws6
bindsym $mod+7 workspace number $ws7
bindsym $mod+8 workspace number $ws8
bindsym $mod+9 workspace number $ws9
bindsym $mod+0 workspace number $ws10

bindsym $mod+Shift+1 move container to workspace number $ws1
bindsym $mod+Shift+2 move container to workspace number $ws2
bindsym $mod+Shift+3 move container to workspace number $ws3
bindsym $mod+Shift+4 move container to workspace number $ws4
bindsym $mod+Shift+5 move container to workspace number $ws5
bindsym $mod+Shift+6 move container to workspace number $ws6
bindsym $mod+Shift+7 move container to workspace number $ws7
bindsym $mod+Shift+8 move container to workspace number $ws8
bindsym $mod+Shift+9 move container to workspace number $ws9
bindsym $mod+Shift+0 move container to workspace number $ws10

# ---------- SCRATCHPAD ----------
bindsym $mod+minus scratchpad show
bindsym $mod+Shift+minus move scratchpad

# ---------- MODO REDIMENSIONAR ----------
mode "resize" {
    bindsym h resize shrink width 10 px or 5 ppt
    bindsym j resize grow height 10 px or 5 ppt
    bindsym k resize shrink height 10 px or 5 ppt
    bindsym l resize grow width 10 px or 5 ppt
    bindsym Left resize shrink width 10 px or 5 ppt
    bindsym Down resize grow height 10 px or 5 ppt
    bindsym Up resize shrink height 10 px or 5 ppt
    bindsym Right resize grow width 10 px or 5 ppt
    bindsym Shift+h resize shrink width 50 px or 10 ppt
    bindsym Shift+j resize grow height 50 px or 10 ppt
    bindsym Shift+k resize shrink height 50 px or 10 ppt
    bindsym Shift+l resize grow width 50 px or 10 ppt
    bindsym Return mode "default"
    bindsym Escape mode "default"
    bindsym $mod+r mode "default"
}

bindsym $mod+r mode "resize"

# ---------- MODO SAIDA ----------
set $mode_system System: (l) lock, (e) logout, (s) suspend, (r) reboot, (Shift+s) shutdown
mode "$mode_system" {
    bindsym l exec --no-startup-id i3lock, mode "default"
    bindsym e exec --no-startup-id i3-msg exit, mode "default"
    bindsym s exec --no-startup-id systemctl suspend, mode "default"
    bindsym r exec --no-startup-id systemctl reboot, mode "default"
    bindsym Shift+s exec --no-startup-id systemctl poweroff, mode "default"
    bindsym Return mode "default"
    bindsym Escape mode "default"
}

bindsym $mod+Shift+e mode "$mode_system"

# ---------- VOLUME E BRILHO ----------
bindsym XF86AudioRaiseVolume exec --no-startup-id pactl set-sink-volume @DEFAULT_SINK@ +5%
bindsym XF86AudioLowerVolume exec --no-startup-id pactl set-sink-volume @DEFAULT_SINK@ -5%
bindsym XF86AudioMute exec --no-startup-id pactl set-sink-mute @DEFAULT_SINK@ toggle
bindsym XF86AudioMicMute exec --no-startup-id pactl set-source-mute @DEFAULT_SOURCE toggle
bindsym XF86MonBrightnessUp exec --no-startup-id brightnessctl set +5%
bindsym XF86MonBrightnessDown exec --no-startup-id brightnessctl set 5%-

# ---------- REGRAS DE JANELAS ----------
for_window [class="Pavucontrol"] floating enable
for_window [class="Nm-connection-editor"] floating enable
for_window [class="Thunar" title=".*Properties.*"] floating enable
for_window [class="KeePassXC"] floating enable

# ---------- BARRA ----------
bar {
    status_command i3status-rs ~/.config/i3status-rust/config.toml
    position top
    modifier none
    font pango:JetBrainsMono Nerd Font 10
    height 28
    separator_symbol "│"

    colors {
        background #1d2021
        statusline #ebdbb2
        separator #3c3836
        focused_workspace  #fe8019 #fe8019 #1d2021
        active_workspace   #3c3836 #3c3836 #ebdbb2
        inactive_workspace #1d2021 #1d2021 #928374
        urgent_workspace   #fb4934 #fb4934 #1d2021
        binding_mode       #fe8019 #fe8019 #1d2021
    }
}
